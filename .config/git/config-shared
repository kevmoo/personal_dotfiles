# Shared Git Configuration (Tracked)

[init]
	defaultBranch = main

[alias]
	lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
	fa = fetch --all --prune
	fp = "!git fa; git pull --ff-only"
	amend = commit --amend -a
	gp = grep -F
	frk = !gh repo fork --remote-name=kevmoo --remote && gh repo set-default origin

[color]
	ui = auto

[url "git@github.com:"]
	insteadOf = https://github.com/
