#!/bin/bash

# Colors for premium Cupertino/Darwin aesthetic
CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
RED='\033[0;31m'
BOLD='\033[1m'
NC='\033[0m' # No Color

echo -e "${CYAN}${BOLD}🍏 Homebrew Environment Audit${NC}"
echo -e "Comparing current state against local Brewfiles...\n"

# Get current installed items
INSTALLED_FORMULAE=$(brew leaves)
INSTALLED_CASKS=$(brew list --cask)

# Get expected items from config
BREWFILE_SHARED="$HOME/.config/brew/Brewfile.shared"
BREWFILE_MAC="$HOME/.config/brew/Brewfile.mac"

EXPECTED_FORMULAE=$(grep '^brew "' "$BREWFILE_SHARED" "$BREWFILE_MAC" 2>/dev/null | sed -E 's/.*brew "([^"]+)".*/\1/')
EXPECTED_CASKS=$(grep '^cask "' "$BREWFILE_SHARED" "$BREWFILE_MAC" 2>/dev/null | sed -E 's/.*cask "([^"]+)".*/\1/')

# 1. Unmanaged items (installed but NOT in Brewfile)
UNMANAGED_FORMULAE=()
for f in $INSTALLED_FORMULAE; do
    if ! echo "$EXPECTED_FORMULAE" | grep -qx "$f"; then
        UNMANAGED_FORMULAE+=("$f")
    fi
done

UNMANAGED_CASKS=()
for c in $INSTALLED_CASKS; do
    if ! echo "$EXPECTED_CASKS" | grep -qx "$c"; then
        UNMANAGED_CASKS+=("$c")
    fi
done

# 2. Missing items (in Brewfile but NOT installed)
MISSING_FORMULAE=()
for f in $EXPECTED_FORMULAE; do
    if ! echo "$INSTALLED_FORMULAE" | grep -qx "$f" && ! brew list --formula | grep -qx "$f"; then
        MISSING_FORMULAE+=("$f")
    fi
done

MISSING_CASKS=()
for c in $EXPECTED_CASKS; do
    if ! echo "$INSTALLED_CASKS" | grep -qx "$c"; then
        MISSING_CASKS+=("$c")
    fi
done

# Output Unmanaged Formulae
if [ ${#UNMANAGED_FORMULAE[@]} -eq 0 ]; then
    echo -e "✨ ${GREEN}All active formulae are tracked in your Brewfiles!${NC}"
else
    echo -e "📦 ${YELLOW}${BOLD}Formulae installed but NOT in Brewfiles:${NC}"
    for f in "${UNMANAGED_FORMULAE[@]}"; do
        echo -e "  - ${YELLOW}$f${NC}"
    done
fi

echo ""

# Output Unmanaged Casks
if [ ${#UNMANAGED_CASKS[@]} -eq 0 ]; then
    echo -e "✨ ${GREEN}All active casks are tracked in your Brewfiles!${NC}"
else
    echo -e "🖥️  ${YELLOW}${BOLD}Casks installed but NOT in Brewfiles:${NC}"
    for c in "${UNMANAGED_CASKS[@]}"; do
        echo -e "  - ${YELLOW}$c${NC}"
    done
fi

echo ""

# Output Missing Formulae/Casks (if any)
if [ ${#MISSING_FORMULAE[@]} -gt 0 ] || [ ${#MISSING_CASKS[@]} -gt 0 ]; then
    echo -e "⚠️  ${RED}${BOLD}Configured in Brewfiles but NOT installed:${NC}"
    for f in "${MISSING_FORMULAE[@]}"; do
        echo -e "  - ${RED}$f${NC} (formula)"
    done
    for c in "${MISSING_CASKS[@]}"; do
        echo -e "  - ${RED}$c${NC} (cask)"
    done
    echo ""
fi

# Check if interactive flag is passed or prompt the user
INTERACTIVE=false
if [[ "$1" == "--interactive" || "$1" == "-i" ]]; then
    INTERACTIVE=true
else
    # If there is anything to configure, ask the user
    if [ ${#UNMANAGED_FORMULAE[@]} -gt 0 ] || [ ${#UNMANAGED_CASKS[@]} -gt 0 ] || [ ${#MISSING_FORMULAE[@]} -gt 0 ] || [ ${#MISSING_CASKS[@]} -gt 0 ]; then
        read -p "Would you like to manage these packages interactively? [y/N]: " yn
        if [[ "$yn" =~ ^[Yy]$ ]]; then
            INTERACTIVE=true
            echo ""
        fi
    fi
fi

if [ "$INTERACTIVE" = true ]; then
    echo -e "${CYAN}${BOLD}Interactive Management Mode Started${NC}\n"

    # Handle Unmanaged Formulae
    if [ ${#UNMANAGED_FORMULAE[@]} -gt 0 ]; then
        echo -e "${CYAN}Managing unmanaged Formulae:${NC}"
        for f in "${UNMANAGED_FORMULAE[@]}"; do
            while true; do
                read -p "Add formula '$f' to Brewfile? [s]hared, [m]ac, or [n]o: " choice
                case "$choice" in
                    s|S)
                        echo "brew \"$f\"" >> "$BREWFILE_SHARED"
                        echo -e "${GREEN}Added '$f' to Brewfile.shared${NC}"
                        break
                        ;;
                    m|M)
                        echo "brew \"$f\"" >> "$BREWFILE_MAC"
                        echo -e "${GREEN}Added '$f' to Brewfile.mac${NC}"
                        break
                        ;;
                    n|N|"")
                        echo -e "${YELLOW}Skipped '$f'${NC}"
                        break
                        ;;
                    *)
                        echo "Invalid option. Please enter s, m, or n."
                        ;;
                esac
            done
        done
        echo ""
    fi

    # Handle Unmanaged Casks
    if [ ${#UNMANAGED_CASKS[@]} -gt 0 ]; then
        echo -e "${CYAN}Managing unmanaged Casks:${NC}"
        for c in "${UNMANAGED_CASKS[@]}"; do
            while true; do
                read -p "Add cask '$c' to Brewfile? [s]hared, [m]ac, or [n]o: " choice
                case "$choice" in
                    s|S)
                        echo "cask \"$c\"" >> "$BREWFILE_SHARED"
                        echo -e "${GREEN}Added '$c' to Brewfile.shared${NC}"
                        break
                        ;;
                    m|M)
                        echo "cask \"$c\"" >> "$BREWFILE_MAC"
                        echo -e "${GREEN}Added '$c' to Brewfile.mac${NC}"
                        break
                        ;;
                    n|N|"")
                        echo -e "${YELLOW}Skipped '$c'${NC}"
                        break
                        ;;
                    *)
                        echo "Invalid option. Please enter s, m, or n."
                        ;;
                esac
            done
        done
        echo ""
    fi

    # Handle Missing Formulae
    if [ ${#MISSING_FORMULAE[@]} -gt 0 ]; then
        echo -e "${CYAN}Managing missing Formulae (in config but not installed):${NC}"
        for f in "${MISSING_FORMULAE[@]}"; do
            while true; do
                read -p "Action for formula '$f'? [i]nstall, [r]emove from config, or [k]eep: " choice
                case "$choice" in
                    i|I)
                        echo -e "${CYAN}Running: brew install $f${NC}"
                        brew install "$f"
                        break
                        ;;
                    r|R)
                        # Remove from whichever Brewfile contains it
                        if grep -q "brew \"$f\"" "$BREWFILE_SHARED"; then
                            sed -i '' "/brew \"$f\"/d" "$BREWFILE_SHARED"
                            echo -e "${GREEN}Removed '$f' from Brewfile.shared${NC}"
                        elif grep -q "brew \"$f\"" "$BREWFILE_MAC"; then
                            sed -i '' "/brew \"$f\"/d" "$BREWFILE_MAC"
                            echo -e "${GREEN}Removed '$f' from Brewfile.mac${NC}"
                        fi
                        break
                        ;;
                    k|K|"")
                        echo -e "${YELLOW}Kept configuration for '$f'${NC}"
                        break
                        ;;
                    *)
                        echo "Invalid option. Please enter i, r, or k."
                        ;;
                esac
            done
        done
        echo ""
    fi

    # Handle Missing Casks
    if [ ${#MISSING_CASKS[@]} -gt 0 ]; then
        echo -e "${CYAN}Managing missing Casks (in config but not installed):${NC}"
        for c in "${MISSING_CASKS[@]}"; do
            while true; do
                read -p "Action for cask '$c'? [i]nstall, [r]emove from config, or [k]eep: " choice
                case "$choice" in
                    i|I)
                        echo -e "${CYAN}Running: brew install --cask $c${NC}"
                        brew install --cask "$c"
                        break
                        ;;
                    r|R)
                        # Remove from whichever Brewfile contains it
                        if grep -q "cask \"$c\"" "$BREWFILE_SHARED"; then
                            sed -i '' "/cask \"$c\"/d" "$BREWFILE_SHARED"
                            echo -e "${GREEN}Removed '$c' from Brewfile.shared${NC}"
                        elif grep -q "cask \"$c\"" "$BREWFILE_MAC"; then
                            sed -i '' "/cask \"$c\"/d" "$BREWFILE_MAC"
                            echo -e "${GREEN}Removed '$c' from Brewfile.mac${NC}"
                        fi
                        break
                        ;;
                    k|K|"")
                        echo -e "${YELLOW}Kept configuration for '$c'${NC}"
                        break
                        ;;
                    *)
                        echo "Invalid option. Please enter i, r, or k."
                        ;;
                esac
            done
        done
        echo ""
    fi

    echo -e "${GREEN}${BOLD}✨ Interactive configuration sync completed successfully!${NC}"
else
    echo -e "${CYAN}Tip: Run 'brew-check --interactive' (or 'brew-check -i') to resolve these differences interactively.${NC}"
fi
